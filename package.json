{
  "name": "pdf-smart-reader",
  "version": "1.2.1",
  "description": "PDF 智能阅读器 - Electron + React + TypeScript",
  "main": "./out/main/index.js",
  "author": "PDF Smart Reader",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "electron-vite build && electron-builder --win",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "animal-island-ui": "^0.9.4",
    "electron-store": "^8.2.0",
    "pdfjs-dist": "^4.4.168",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^35.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "patch-package": "^8.0.1",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.pdfsmartreader.app",
    "productName": "PDF Smart Reader",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "artifactName": "PDF-Smart-Reader-Setup.exe"
    }
  }
}
